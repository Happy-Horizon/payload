{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "package.json",
    "pnpm-lock.yaml",
    "tsconfig.base.json"
  ],
  "tasks": {
    "clean": {
      "cache": false,
      "dependsOn": ["^clean"]
    },
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "outputs": ["./dist/**"]
    },
    "dev": {
      "cache": false
    },
    "lint": {
      "cache": true,
      "dependsOn": ["^build"]
    },
    "lint:fix": {
      "cache": false
    },
    "test": {
      "cache": true,
      "dependsOn": ["^build"]
    },
    "prettier:fix": {
      "cache": false
    }
  }
}
